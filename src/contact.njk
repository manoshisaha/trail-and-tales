<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Contact – The Unchained Girl</title>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'DM Sans',sans-serif;background:#f9f6f0;color:#1c1c1c;}
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:1rem 3rem;background:rgba(249,246,240,0.93);backdrop-filter:blur(12px);border-bottom:1px solid rgba(28,28,28,0.08);}
.nav-logo{font-family:'Playfair Display',serif;font-size:1.3rem;color:#1a3a2a;text-decoration:none;font-weight:700;font-style:italic;}
.nav-logo span{color:#d4501a;}
.nav-links{display:flex;gap:2rem;list-style:none;}
.nav-links a{font-size:0.85rem;font-weight:500;letter-spacing:0.05em;text-decoration:none;color:#1c1c1c;text-transform:uppercase;}
.nav-links a:hover{color:#d4501a;}
.nav-cta{background:#d4501a;color:#fff!important;padding:0.5rem 1.2rem;border-radius:2rem;}
.page-hero{background:#1a3a2a;color:#fff;padding:8rem 4rem 5rem;margin-top:72px;}
.page-hero-eyebrow{font-size:0.75rem;letter-spacing:0.2em;text-transform:uppercase;color:#e8b84b;margin-bottom:1rem;font-weight:500;}
.page-hero h1{font-family:'Playfair Display',serif;font-size:clamp(2.5rem,5vw,4rem);font-weight:900;line-height:1.1;}
.page-hero p{font-size:1.1rem;color:rgba(255,255,255,0.75);max-width:500px;margin-top:1.5rem;line-height:1.7;}
.contact-body{max-width:860px;margin:0 auto;padding:5rem 2rem 6rem;}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;}
.contact-info h2{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:700;margin-bottom:1.2rem;}
.contact-info p{font-size:0.95rem;line-height:1.8;color:#555;margin-bottom:1.5rem;}
.contact-item{display:flex;align-items:flex-start;gap:1rem;margin-bottom:1.5rem;}
.contact-icon{width:44px;height:44px;border-radius:50%;background:#f5f0e8;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;}
.contact-item-text h4{font-weight:600;font-size:0.9rem;margin-bottom:0.2rem;}
.contact-item-text p{font-size:0.85rem;color:#777;}
.contact-item-text a{color:#d4501a;text-decoration:none;}
.contact-form{background:#fff;border-radius:20px;padding:2.5rem;box-shadow:0 4px 24px rgba(0,0,0,0.07);}
.contact-form h3{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;margin-bottom:1.5rem;}
.form-group{margin-bottom:1.2rem;}
.form-group label{display:block;font-size:0.82rem;font-weight:500;text-transform:uppercase;letter-spacing:0.08em;color:#888;margin-bottom:0.4rem;}
.form-group input,.form-group textarea,.form-group select{width:100%;padding:0.85rem 1rem;border:1.5px solid #e8e8e8;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:0.9rem;background:#fafafa;transition:border-color 0.2s;outline:none;}
.form-group input:focus,.form-group textarea:focus{border-color:#d4501a;background:#fff;}
.form-group textarea{height:140px;resize:vertical;}
.submit-btn{width:100%;background:#d4501a;color:#fff;border:none;padding:1rem;border-radius:3rem;font-family:'DM Sans',sans-serif;font-size:0.95rem;font-weight:500;cursor:pointer;}
.submit-btn:hover{background:#1a3a2a;}
.success-msg{display:none;background:#e8f5ed;color:#2d7a4f;padding:1rem;border-radius:10px;text-align:center;margin-top:1rem;font-size:0.9rem;}
.error-msg{display:none;background:#fde8e8;color:#c0392b;padding:1rem;border-radius:10px;text-align:center;margin-top:1rem;font-size:0.9rem;}
footer{background:#1c1c1c;color:rgba(255,255,255,0.65);padding:2rem 4rem;}
.footer-bottom{display:flex;justify-content:space-between;font-size:0.78rem;flex-wrap:wrap;gap:1rem;}
.footer-bottom a{color:rgba(255,255,255,0.4);text-decoration:none;margin-left:1.5rem;}
.footer-bottom a:hover{color:#e8b84b;}
@media(max-width:768px){nav{padding:1rem 1.5rem;}.nav-links{display:none;}.page-hero{padding:6rem 1.5rem 3rem;}.contact-body{padding:3rem 1.5rem;}.contact-grid{grid-template-columns:1fr;}.footer{padding:2rem 1.5rem;}}
</style>
</head>
<body>
<nav>
  <a class="nav-logo" href="/"><span>The</span> Unchained Girl</a>
  <ul class="nav-links">
    <li><a href="/#blog">Stories</a></li>
    <li><a href="/about/">About</a></li>
    <li><a href="/contact/">Contact</a></li>
    <li><a href="/#newsletter" class="nav-cta">Subscribe</a></li>
  </ul>
</nav>
<div class="page-hero">
  <p class="page-hero-eyebrow">✦ Let's connect</p>
  <h1>Get in Touch</h1>
  <p>Whether you want to collaborate, share your own travel story, or just say hello — I'd love to hear from you.</p>
</div>
<div class="contact-body">
  <div class="contact-grid">
    <div class="contact-info">
      <h2>Let's talk travel</h2>
      <p>I'm always open to connecting with fellow travelers, brands, tourism boards, and anyone who loves honest storytelling about food and adventure.</p>
      <div class="contact-item">
        <div class="contact-icon">📧</div>
        <div class="contact-item-text">
          <h4>Email</h4>
          <p><a href="mailto:hello@theunchainedgirl.com">hello@theunchainedgirl.com</a></p>
        </div>
      </div>
      <div class="contact-item">
        <div class="contact-icon">🤝</div>
        <div class="contact-item-text">
          <h4>Collaborations</h4>
          <p>Travel brands, hotels, tourism boards, restaurants — let's work together authentically.</p>
        </div>
      </div>
      <div class="contact-item">
        <div class="contact-icon">📍</div>
        <div class="contact-item-text">
          <h4>Based in</h4>
          <p>Dhaka, Bangladesh 🇧🇩</p>
        </div>
      </div>
      <div class="contact-item">
        <div class="contact-icon">⏱</div>
        <div class="contact-item-text">
          <h4>Response time</h4>
          <p>I reply within 2–3 business days.</p>
        </div>
      </div>
    </div>
    <div class="contact-form">
      <h3>Send a message</h3>
      <div class="form-group">
        <label>Your Name</label>
        <input type="text" id="name" placeholder="Your name">
      </div>
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" id="email" placeholder="you@email.com">
      </div>
      <div class="form-group">
        <label>Subject</label>
        <select id="subject">
          <option>General Hello</option>
          <option>Collaboration / Sponsorship</option>
          <option>Travel Question</option>
          <option>Press / Media</option>
          <option>Other</option>
        </select>
      </div>
      <div class="form-group">
        <label>Message</label>
        <textarea id="message" placeholder="Tell me what's on your mind..."></textarea>
      </div>
      <button class="submit-btn" onclick="handleSubmit()">Send Message →</button>
      <div class="success-msg" id="successMsg">✓ Message sent! I'll get back to you within 2–3 days.</div>
      <div class="error-msg" id="errorMsg">❌ Something went wrong. Please email me directly at hello@theunchainedgirl.com</div>
    </div>
  </div>
</div>
<footer>
  <div class="footer-bottom">
    <span>© 2025 The Unchained Girl · Made with ✦ in Bangladesh</span>
    <div>
      <a href="/about/">About</a>
      <a href="/contact/">Contact</a>
      <a href="/privacy-policy/">Privacy Policy</a>
      <a href="/terms/">Terms</a>
    </div>
  </div>
</footer>
<script>
async function handleSubmit(){
  const name=document.getElementById('name').value.trim();
  const email=document.getElementById('email').value.trim();
  const subject=document.getElementById('subject').value;
  const message=document.getElementById('message').value.trim();
  if(!name||!email||!message){alert('Please fill in all fields.');return;}
  try{
    const res=await fetch('https://formspree.io/f/xgopprkz',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({name,email,subject,message})
    });
    if(res.ok){
      document.getElementById('successMsg').style.display='block';
      document.getElementById('name').value='';
      document.getElementById('email').value='';
      document.getElementById('message').value='';
    } else {
      document.getElementById('errorMsg').style.display='block';
    }
  } catch(e){
    document.getElementById('errorMsg').style.display='block';
  }
}
</script>
</body>
</html>
