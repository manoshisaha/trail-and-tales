---
layout: base.njk
title: Home
---

{% block extrahead %}
<style>
/* HERO */
.hero{min-height:100vh;display:grid;grid-template-columns:1fr 1fr;padding-top:72px;overflow:hidden;}
.hero-left{display:flex;flex-direction:column;justify-content:center;padding:6rem 4rem;background:var(--forest);color:#fff;position:relative;}
.hero-left::after{content:'';position:absolute;right:-40px;top:0;bottom:0;width:80px;background:var(--forest);clip-path:polygon(0 0,0 100%,100% 100%);z-index:1;}
.hero-eyebrow{font-size:0.75rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);margin-bottom:1.5rem;font-weight:500;}
.hero-title{font-family:'Playfair Display',serif;font-size:clamp(3rem,5vw,5.5rem);line-height:1.0;margin-bottom:1.5rem;font-weight:900;}
.hero-title em{color:var(--gold);font-style:italic;}
.hero-sub{font-size:1.05rem;line-height:1.7;color:rgba(255,255,255,0.75);max-width:420px;margin-bottom:2.5rem;}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap;}
.btn-primary{background:var(--clay);color:#fff;padding:0.9rem 2rem;border-radius:3rem;text-decoration:none;font-weight:500;font-size:0.9rem;transition:transform 0.2s,box-shadow 0.2s;display:inline-block;}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(212,80,26,0.4);}
.btn-outline{border:1px solid rgba(255,255,255,0.4);color:#fff;padding:0.9rem 2rem;border-radius:3rem;text-decoration:none;font-weight:500;font-size:0.9rem;transition:background 0.2s;display:inline-block;}
.btn-outline:hover{background:rgba(255,255,255,0.1);}
.hero-right{position:relative;background:var(--sand);overflow:hidden;}
.hero-img-grid{display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;height:100%;gap:4px;}
.hero-img-grid .img-block{overflow:hidden;position:relative;}
.hero-img-grid .img-block img{width:100%;height:100%;object-fit:cover;transition:transform 0.6s ease;}
.hero-img-grid .img-block:hover img{transform:scale(1.05);}
.hero-img-grid .img-block:first-child{grid-row:span 2;}
.hero-stats{position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);display:flex;gap:2rem;background:rgba(255,255,255,0.9);backdrop-filter:blur(10px);padding:1rem 2rem;border-radius:3rem;box-shadow:0 8px 32px rgba(0,0,0,0.1);z-index:2;white-space:nowrap;}
.stat{text-align:center;}
.stat-num{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;color:var(--clay);}
.stat-label{font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:#666;}

/* FILTERS */
.filters-section{padding:2.5rem 4rem 1.5rem;background:var(--mist);position:sticky;top:72px;z-index:50;border-bottom:1px solid rgba(0,0,0,0.06);}
.filter-row{display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;}
.filter-label{font-size:0.75rem;text-transform:uppercase;letter-spacing:0.12em;color:#888;font-weight:500;margin-right:0.25rem;}
.filter-chip{padding:0.4rem 1.1rem;border-radius:2rem;border:1.5px solid #ddd;font-size:0.82rem;font-weight:500;cursor:pointer;background:#fff;transition:all 0.2s;color:var(--ink);}
.filter-chip:hover{border-color:var(--clay);color:var(--clay);}
.filter-chip.active{background:var(--clay);color:#fff;border-color:var(--clay);}
.filter-divider{width:1px;height:24px;background:#ddd;margin:0 0.25rem;}

/* BLOG SECTION */
.blog-section{padding:3rem 4rem 5rem;}
.blog-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:2.5rem;}
.section-eyebrow{font-size:0.72rem;text-transform:uppercase;letter-spacing:0.2em;color:var(--clay);font-weight:500;margin-bottom:0.4rem;}
.section-title{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,3vw,2.6rem);font-weight:700;line-height:1.15;}

/* BLOG GRID */
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;}
.blog-card{background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,0.05);transition:transform 0.3s,box-shadow 0.3s;text-decoration:none;color:inherit;display:block;}
.blog-card:hover{transform:translateY(-6px);box-shadow:0 16px 40px rgba(0,0,0,0.12);}
.blog-card.featured{grid-column:span 2;display:grid;grid-template-columns:1fr 1fr;}
.card-img{position:relative;overflow:hidden;aspect-ratio:4/3;}
.blog-card.featured .card-img{aspect-ratio:unset;height:100%;}
.card-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.5s;}
.blog-card:hover .card-img img{transform:scale(1.06);}
.card-img .no-img{width:100%;height:100%;background:linear-gradient(135deg,var(--forest),var(--sky));display:flex;align-items:center;justify-content:center;font-size:3rem;}
.card-category{position:absolute;top:1rem;left:1rem;background:var(--clay);color:#fff;font-size:0.68rem;font-weight:500;text-transform:uppercase;letter-spacing:0.1em;padding:0.3rem 0.8rem;border-radius:2rem;}
.card-location{position:absolute;top:1rem;right:1rem;background:rgba(0,0,0,0.55);color:#fff;font-size:0.68rem;padding:0.3rem 0.75rem;border-radius:2rem;backdrop-filter:blur(4px);}
.card-body{padding:1.5rem;}
.card-meta{font-size:0.72rem;color:#999;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.6rem;}
.card-title{font-family:'Playfair Display',serif;font-size:1.15rem;line-height:1.3;margin-bottom:0.65rem;font-weight:700;}
.blog-card.featured .card-title{font-size:1.55rem;}
.card-excerpt{font-size:0.88rem;line-height:1.65;color:#666;margin-bottom:1.1rem;}
.card-footer{display:flex;align-items:center;justify-content:space-between;}
.card-tags{display:flex;gap:0.4rem;flex-wrap:wrap;}
.card-tag{font-size:0.7rem;padding:0.2rem 0.65rem;border-radius:2rem;background:var(--sand);color:#555;font-weight:500;}
.card-read{font-size:0.75rem;color:#999;}
.blog-card.hidden{display:none!important;}
.no-posts{text-align:center;padding:4rem 2rem;color:#888;font-size:1rem;grid-column:1/-1;}

/* NEWSLETTER */
.newsletter{padding:5rem 4rem;background:var(--clay);color:#fff;text-align:center;position:relative;overflow:hidden;}
.newsletter::before{content:'TRAVEL';position:absolute;font-family:'Bebas Neue',sans-serif;font-size:20rem;color:rgba(255,255,255,0.05);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;white-space:nowrap;}
.newsletter h2{font-family:'Playfair Display',serif;font-size:2.6rem;font-weight:900;margin-bottom:1rem;position:relative;z-index:1;}
.newsletter p{font-size:1rem;color:rgba(255,255,255,0.8);max-width:480px;margin:0 auto 2rem;position:relative;z-index:1;}
.newsletter-form{display:flex;gap:0;max-width:440px;margin:0 auto;position:relative;z-index:1;}
.newsletter-form input{flex:1;padding:1rem 1.5rem;border:none;border-radius:3rem 0 0 3rem;font-family:'DM Sans',sans-serif;font-size:0.9rem;outline:none;}
.newsletter-form button{background:var(--forest);color:#fff;border:none;padding:1rem 1.8rem;border-radius:0 3rem 3rem 0;font-family:'DM Sans',sans-serif;font-size:0.9rem;font-weight:500;cursor:pointer;transition:background 0.2s;white-space:nowrap;}
.newsletter-form button:hover{background:var(--ink);}
.newsletter-note{font-size:0.75rem;color:rgba(255,255,255,0.5);margin-top:1rem;position:relative;z-index:1;}

@media(max-width:1100px){.blog-grid{grid-template-columns:repeat(2,1fr);}.blog-card.featured{grid-column:span 2;}}
@media(max-width:768px){
  .hero{grid-template-columns:1fr;}.hero-right{display:none;}.hero-left{padding:5rem 2rem 4rem;}
  .filters-section,.blog-section{padding-left:1.5rem;padding-right:1.5rem;}
  .blog-grid{grid-template-columns:1fr;}
  .blog-card.featured{grid-column:span 1;grid-template-columns:1fr;}
  .blog-card.featured .card-img{height:200px;}
  .newsletter{padding:3.5rem 1.5rem;}
  .newsletter-form{flex-direction:column;}
  .newsletter-form input,.newsletter-form button{border-radius:3rem;}
}
</style>
{% endblock %}

{% block content %}

<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <p class="hero-eyebrow">✦ Stories from the road</p>
    <h1 class="hero-title">Every Trail<br>Has a <em>Tale</em><br>to Tell.</h1>
    <p class="hero-sub">From the misty hills of home to the buzzing streets abroad — honest travel stories, food finds, trekking trails, and the connections that make it all worth it.</p>
    <div class="hero-btns">
      <a href="#blog" class="btn-primary">Read Stories</a>
      <a href="#blog" class="btn-outline">Explore Destinations</a>
    </div>
  </div>
  <div class="hero-right">
    <div class="hero-img-grid">
      <div class="img-block"><img src="https://images.unsplash.com/photo-1501854140801-50d01698950b?w=600&q=80" alt="Mountain trail"></div>
      <div class="img-block"><img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=400&q=80" alt="Street food"></div>
      <div class="img-block"><img src="https://images.unsplash.com/photo-1528360983277-13d401cdc186?w=400&q=80" alt="Local market"></div>
    </div>
    <div class="hero-stats">
      <div class="stat"><div class="stat-num">{{ collections.posts | length }}</div><div class="stat-label">Stories</div></div>
      <div class="stat"><div class="stat-num">18</div><div class="stat-label">Countries</div></div>
      <div class="stat"><div class="stat-num">12k</div><div class="stat-label">Readers</div></div>
    </div>
  </div>
</section>

<!-- FILTERS -->
<div class="filters-section" id="blog">
  <div class="filter-row">
    <span class="filter-label">Where:</span>
    <button class="filter-chip active" onclick="filterPosts(this,'region','all')">🌍 All</button>
    <button class="filter-chip" onclick="filterPosts(this,'region','home-country')">🇧🇩 Home Country</button>
    <button class="filter-chip" onclick="filterPosts(this,'region','abroad')">✈️ Abroad</button>
    <div class="filter-divider"></div>
    <span class="filter-label">Vibe:</span>
    <button class="filter-chip" onclick="filterPosts(this,'vibe','food')">🍜 Food</button>
    <button class="filter-chip" onclick="filterPosts(this,'vibe','trek')">🥾 Trek</button>
    <button class="filter-chip" onclick="filterPosts(this,'vibe','relax')">🌊 Relax</button>
    <button class="filter-chip" onclick="filterPosts(this,'vibe','community')">🤝 Community</button>
    <button class="filter-chip" onclick="filterPosts(this,'vibe','nature')">🌿 Nature</button>
  </div>
</div>

<!-- BLOG GRID -->
<section class="blog-section">
  <div class="blog-header">
    <div>
      <p class="section-eyebrow">Latest from the road</p>
      <h2 class="section-title">Recent Stories</h2>
    </div>
  </div>
  <div class="blog-grid" id="blogGrid">
    {% set posts = collections.posts | reverse %}
    {% if posts.length == 0 %}
      <div class="no-posts">
        <p style="font-size:2rem;margin-bottom:1rem">✍️</p>
        <p>No posts yet — go to <a href="/admin/" style="color:var(--clay);">/admin</a> to write your first story!</p>
      </div>
    {% else %}
      {% for post in posts %}
        {% set isFirst = loop.first %}
        <a href="{{ post.url }}"
           class="blog-card {% if isFirst %}featured{% endif %}"
           data-region="{{ post.data.region | slugify }}"
           data-vibe="{{ post.data.category | slugify }}">
          <div class="card-img">
            {% if post.data.cover_image %}
              <img src="{{ post.data.cover_image }}" alt="{{ post.data.title }}" loading="lazy">
            {% else %}
              <div class="no-img">✈️</div>
            {% endif %}
            {% if post.data.category %}<span class="card-category">{{ post.data.category }}</span>{% endif %}
            {% if post.data.location %}<span class="card-location">📍 {{ post.data.location }}</span>{% endif %}
          </div>
          <div class="card-body">
            <p class="card-meta">{{ post.data.date | dateDisplay }}{% if post.data.read_time %} · {{ post.data.read_time }} min read{% endif %}</p>
            <h3 class="card-title">{{ post.data.title }}</h3>
            {% if post.data.excerpt %}<p class="card-excerpt">{{ post.data.excerpt }}</p>{% endif %}
            <div class="card-footer">
              <div class="card-tags">
                {% if post.data.category %}<span class="card-tag">{{ post.data.category }}</span>{% endif %}
                {% if post.data.region %}<span class="card-tag">{{ post.data.region }}</span>{% endif %}
              </div>
              {% if post.data.read_time %}<span class="card-read">{{ post.data.read_time }} min</span>{% endif %}
            </div>
          </div>
        </a>
      {% endfor %}
    {% endif %}
  </div>
</section>

<!-- NEWSLETTER -->
<section class="newsletter" id="newsletter">
  <h2>Get Stories Before They're Live</h2>
  <p>New posts, destination guides, and exclusive tips — delivered to your inbox. No spam, ever.</p>
  <div class="newsletter-form">
    <input type="email" id="emailInput" placeholder="your@email.com">
    <button onclick="handleSubscribe()">Subscribe Free</button>
  </div>
  <p class="newsletter-note">Join 12,000+ readers · Unsubscribe any time</p>
</section>

{% endblock %}

{% block scripts %}
<script>
let activeRegion='all', activeVibe=null;
function filterPosts(btn,type,val){
  const allChips=document.querySelectorAll(`.filter-chip[onclick*="${type}"]`);
  allChips.forEach(c=>c.classList.remove('active'));
  btn.classList.add('active');
  if(type==='region') activeRegion=val;
  if(type==='vibe'){
    activeVibe=(activeVibe===val)?null:val;
    if(!activeVibe) btn.classList.remove('active');
  }
  document.querySelectorAll('.blog-card').forEach(card=>{
    const r=card.dataset.region, v=card.dataset.vibe;
    const rOk=activeRegion==='all'||r===activeRegion;
    const vOk=!activeVibe||v===activeVibe;
    card.classList.toggle('hidden',!(rOk&&vOk));
  });
  // re-apply featured to first visible card
  document.querySelectorAll('.blog-card.featured').forEach(c=>c.classList.remove('featured'));
  const visible=[...document.querySelectorAll('.blog-card:not(.hidden)')];
  if(visible.length>0) visible[0].classList.add('featured');
}
function handleSubscribe(){
  const input=document.getElementById('emailInput');
  if(input.value&&input.value.includes('@')){
    input.value='';input.placeholder='✓ Subscribed! Thank you.';
  } else {
    input.placeholder='Please enter a valid email';
  }
}
</script>
{% endblock %}
