<script>
/* ═══════════════════════════════════════════
   HERO SLIDESHOW IMAGES — CHANGE THESE!
   Replace the URLs with your own photos.
   To use your own: go to /admin → Media →
   upload photo → copy URL → paste here.
   ═══════════════════════════════════════════ */
const heroImages = [
  'https://images.unsplash.com/photo-1501854140801-50d01698950b?w=1400&q=85',
  'https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=1400&q=85',
  'https://images.unsplash.com/photo-1470770903676-69b98201ea1c?w=1400&q=85',
  'https://images.unsplash.com/photo-1528360983277-13d401cdc186?w=1400&q=85'
];
/* ═══════════════════════════════════════════ */

let currentSlide = 0;
const bg = document.getElementById('heroBg');
const dotsContainer = document.getElementById('heroDots');

// Create dots
heroImages.forEach((_, i) => {
  const dot = document.createElement('button');
  dot.className = 'hero-dot' + (i === 0 ? ' active' : '');
  dot.onclick = () => goToSlide(i);
  dotsContainer.appendChild(dot);
});

function goToSlide(n) {
  currentSlide = n;
  bg.style.backgroundImage = `url('${heroImages[n]}')`;
  document.querySelectorAll('.hero-dot').forEach((d, i) => {
    d.classList.toggle('active', i === n);
  });
}

// Auto-advance every 5 seconds
setInterval(() => {
  goToSlide((currentSlide + 1) % heroImages.length);
}, 5000);

// Nav scroll effect
window.addEventListener('scroll', () => {
  document.getElementById('mainNav').classList.toggle('scrolled', window.scrollY > 50);
});

// Mobile nav
function toggleMenu() { document.getElementById('mobileNav').classList.toggle('open'); }

// Filters
let activeRegion = 'all', activeVibe = null;
function filterPosts(btn, type, val) {
  document.querySelectorAll('.filter-chip[onclick*="' + type + '"]').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  if (type === 'region') activeRegion = val;
  if (type === 'vibe') { activeVibe = (activeVibe === val) ? null : val; if (!activeVibe) btn.classList.remove('active'); }
  document.querySelectorAll('.blog-card').forEach(card => {
    const rOk = activeRegion === 'all' || card.dataset.region === activeRegion;
    const vOk = !activeVibe || card.dataset.vibe === activeVibe;
    card.classList.toggle('hidden', !(rOk && vOk));
  });
}

// Newsletter
function handleSubscribe() {
  const input = document.getElementById('emailInput');
  const email = input.value.trim();
  if (email && email.includes('@')) {
    fetch('https://formspree.io/f/YOUR_FORM_ID', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, subject: 'New Newsletter Subscriber' })
    });
    input.value = '';
    input.placeholder = '✓ Welcome to the community!';
  } else {
    input.placeholder = 'Please enter a valid email';
  }
}
</script>
