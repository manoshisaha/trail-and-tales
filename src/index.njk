<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="google-site-verification" content="AhLdK0P80IAK4RAzPIMC19twFsLraTKNXZK2NausbPY" />
<title>The Unchained Girl – Travel, Food & Adventure from Bangladesh</title>
<meta name="description" content="A Bangladeshi girl exploring the world — food, trails, nature and the people that make it all worthwhile.">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500&family=Baloo+Da+2:wght@400;500;600&family=Bebas+Neue&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans','Baloo Da 2',sans-serif;background:#f9f6f0;color:#1c1c1c;overflow-x:hidden;}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:1rem 3rem;background:rgba(249,246,240,0.93);backdrop-filter:blur(12px);border-bottom:1px solid rgba(28,28,28,0.08);transition:all 0.3s;}
nav.scrolled{background:rgba(249,246,240,0.98);box-shadow:0 2px 20px rgba(0,0,0,0.08);}
.nav-logo{font-family:'Playfair Display',serif;font-size:1.3rem;color:#1a3a2a;text-decoration:none;font-weight:700;font-style:italic;}
.nav-logo span{color:#d4501a;}
.nav-links{display:flex;gap:2rem;list-style:none;}
.nav-links a{font-size:0.85rem;font-weight:500;letter-spacing:0.05em;text-decoration:none;color:#1c1c1c;text-transform:uppercase;transition:color 0.2s;}
.nav-links a:hover{color:#d4501a;}
.nav-cta{background:#d4501a;color:#fff!important;padding:0.5rem 1.2rem;border-radius:2rem;transition:background 0.2s!important;}
.nav-cta:hover{background:#1a3a2a!important;}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;border:none;background:none;padding:4px;}
.hamburger span{display:block;width:24px;height:2px;background:#1c1c1c;transition:0.3s;}
.mobile-nav{display:none;position:fixed;top:0;right:0;bottom:0;width:270px;background:#1a3a2a;z-index:200;padding:5rem 2rem 2rem;flex-direction:column;gap:1.5rem;transform:translateX(100%);transition:transform 0.3s;box-shadow:-4px 0 30px rgba(0,0,0,0.2);}
.mobile-nav.open{transform:translateX(0);}
.mobile-nav a{color:#fff;text-decoration:none;font-size:1.05rem;font-weight:500;padding:0.5rem 0;border-bottom:1px solid rgba(255,255,255,0.1);}

/* ── HERO ── */
.hero{min-height:100vh;position:relative;overflow:hidden;display:flex;align-items:center;padding-top:72px;}

/* ═══════════════════════════════════════════
   HERO IMAGES — CHANGE THESE EASILY!
   Just replace the URLs below with your own photos.
   Upload your photos to /admin → Media, then copy the URL.
   ═══════════════════════════════════════════ */
.hero-bg{
  position:absolute;inset:0;
  background-image:url('https://images.unsplash.com/photo-1501854140801-50d01698950b?w=1400&q=85');
  background-size:cover;background-position:center;
  transition:opacity 1.5s ease;
}
.hero-bg.slide-2{background-image:url('https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=1400&q=85');}
.hero-bg.slide-3{background-image:url('https://images.unsplash.com/photo-1470770903676-69b98201ea1c?w=1400&q=85');}
.hero-bg.slide-4{background-image:url('https://images.unsplash.com/photo-1528360983277-13d401cdc186?w=1400&q=85');}
/* ═══════════════════════════════════════════ */

.hero-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(10,20,15,0.82) 0%,rgba(10,20,15,0.5) 50%,rgba(10,20,15,0.3) 100%);}
.hero-content{position:relative;z-index:2;padding:4rem 5rem;max-width:750px;}
.hero-eyebrow{display:inline-flex;align-items:center;gap:0.5rem;font-size:0.78rem;letter-spacing:0.25em;text-transform:uppercase;color:#e8b84b;margin-bottom:1.5rem;font-weight:500;}
.hero-eyebrow::before{content:'';display:block;width:30px;height:1px;background:#e8b84b;}
.hero-title{font-family:'Playfair Display',serif;font-size:clamp(3rem,6vw,6rem);line-height:1.0;margin-bottom:1.5rem;font-weight:900;color:#fff;}
.hero-title em{color:#e8b84b;font-style:italic;display:block;}
.hero-sub{font-size:1.1rem;line-height:1.8;color:rgba(255,255,255,0.8);max-width:500px;margin-bottom:2.5rem;}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap;}
.btn-primary{background:#d4501a;color:#fff;padding:1rem 2.2rem;border-radius:3rem;text-decoration:none;font-weight:600;font-size:0.9rem;display:inline-flex;align-items:center;gap:0.5rem;transition:all 0.3s;letter-spacing:0.02em;}
.btn-primary:hover{background:#e8b84b;color:#1c1c1c;transform:translateY(-2px);box-shadow:0 8px 24px rgba(212,80,26,0.4);}
.btn-outline{border:2px solid rgba(255,255,255,0.6);color:#fff;padding:1rem 2.2rem;border-radius:3rem;text-decoration:none;font-weight:500;font-size:0.9rem;display:inline-flex;align-items:center;gap:0.5rem;transition:all 0.3s;}
.btn-outline:hover{background:rgba(255,255,255,0.15);border-color:#fff;}

/* Slideshow dots */
.hero-dots{position:absolute;bottom:2rem;left:5rem;display:flex;gap:0.6rem;z-index:3;}
.hero-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.4);cursor:pointer;transition:all 0.3s;border:none;}
.hero-dot.active{background:#e8b84b;width:24px;border-radius:4px;}

/* Hero stats */
.hero-stats{position:absolute;bottom:2rem;right:4rem;display:flex;gap:2rem;z-index:3;}
.hero-stat{text-align:center;}
.hero-stat-num{font-family:'Bebas Neue',sans-serif;font-size:2rem;color:#e8b84b;line-height:1;}
.hero-stat-label{font-size:0.68rem;text-transform:uppercase;letter-spacing:0.12em;color:rgba(255,255,255,0.6);margin-top:0.2rem;}

/* Scroll indicator */
.scroll-indicator{position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);z-index:3;display:flex;flex-direction:column;align-items:center;gap:0.4rem;}
.scroll-indicator span{font-size:0.68rem;text-transform:uppercase;letter-spacing:0.15em;color:rgba(255,255,255,0.5);}
.scroll-line{width:1px;height:40px;background:linear-gradient(to bottom,rgba(255,255,255,0.5),transparent);animation:scrollAnim 1.5s ease-in-out infinite;}
@keyframes scrollAnim{0%{opacity:1;transform:scaleY(1);}100%{opacity:0;transform:scaleY(0.3);transform-origin:top;}}

/* ── MARQUEE STRIP ── */
.marquee-strip{background:#d4501a;padding:0.75rem 0;overflow:hidden;white-space:nowrap;}
.marquee-inner{display:inline-flex;animation:marquee 25s linear infinite;}
.marquee-inner span{font-size:0.8rem;font-weight:600;text-transform:uppercase;letter-spacing:0.15em;color:#fff;padding:0 2rem;}
.marquee-inner span.dot{color:#e8b84b;padding:0 0.5rem;}
@keyframes marquee{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}

/* ── FILTERS ── */
.filters-section{padding:2rem 4rem 1.5rem;background:#f9f6f0;border-bottom:1px solid rgba(0,0,0,0.06);position:sticky;top:72px;z-index:50;}
.filter-row{display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;}
.filter-label{font-size:0.72rem;text-transform:uppercase;letter-spacing:0.15em;color:#aaa;font-weight:600;}
.filter-chip{padding:0.45rem 1.2rem;border-radius:2rem;border:1.5px solid #e0e0e0;font-size:0.82rem;font-weight:500;cursor:pointer;background:#fff;color:#555;transition:all 0.2s;}
.filter-chip:hover,.filter-chip.active{background:#d4501a;color:#fff;border-color:#d4501a;transform:translateY(-1px);box-shadow:0 4px 12px rgba(212,80,26,0.25);}
.filter-divider{width:1px;height:20px;background:#e0e0e0;margin:0 0.25rem;}

/* ── BLOG SECTION ── */
.blog-section{padding:4rem 4rem 6rem;}
.blog-header{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:3rem;}
.section-eyebrow{font-size:0.72rem;text-transform:uppercase;letter-spacing:0.2em;color:#d4501a;font-weight:600;margin-bottom:0.5rem;}
.section-title{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,3vw,2.8rem);font-weight:700;line-height:1.1;}
.view-all-link{font-size:0.85rem;color:#d4501a;text-decoration:none;font-weight:500;display:flex;align-items:center;gap:0.3rem;border-bottom:1px solid #d4501a;padding-bottom:1px;}

/* ── BLOG GRID ── */
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;}
.blog-card{background:#fff;border-radius:20px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,0.05);transition:all 0.35s;text-decoration:none;color:inherit;display:block;}
.blog-card:hover{transform:translateY(-8px);box-shadow:0 20px 50px rgba(0,0,0,0.12);}
.blog-card.featured{grid-column:span 2;display:grid;grid-template-columns:1fr 1fr;}
.card-img{position:relative;overflow:hidden;aspect-ratio:4/3;}
.blog-card.featured .card-img{aspect-ratio:unset;height:100%;}
.card-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.6s ease;}
.blog-card:hover .card-img img{transform:scale(1.07);}
.no-img{width:100%;min-height:220px;height:100%;background:linear-gradient(135deg,#1a3a2a,#4a9ebb);display:flex;align-items:center;justify-content:center;font-size:3rem;}
.card-category{position:absolute;top:1rem;left:1rem;background:#d4501a;color:#fff;font-size:0.68rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;padding:0.35rem 0.9rem;border-radius:2rem;}
.card-location{position:absolute;bottom:1rem;left:1rem;background:rgba(0,0,0,0.6);color:#fff;font-size:0.72rem;padding:0.3rem 0.8rem;border-radius:2rem;backdrop-filter:blur(4px);}
.card-body{padding:1.75rem;}
.card-meta{font-size:0.72rem;color:#bbb;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.6rem;}
.card-title{font-family:'Playfair Display',serif;font-size:1.15rem;line-height:1.35;margin-bottom:0.75rem;font-weight:700;}
.blog-card.featured .card-title{font-size:1.6rem;}
.card-excerpt{font-size:0.88rem;line-height:1.7;color:#777;margin-bottom:1.2rem;}
.card-footer-row{display:flex;align-items:center;justify-content:space-between;}
.card-tags{display:flex;gap:0.4rem;flex-wrap:wrap;}
.card-tag{font-size:0.7rem;padding:0.25rem 0.7rem;border-radius:2rem;background:#f5f0e8;color:#888;font-weight:500;}
.card-read{font-size:0.75rem;color:#bbb;display:flex;align-items:center;gap:0.3rem;}
.blog-card.hidden{display:none!important;}
.no-posts{text-align:center;padding:4rem 2rem;color:#aaa;grid-column:1/-1;}

/* ── ABOUT STRIP ── */
.about-strip{background:#1a3a2a;color:#fff;padding:5rem 4rem;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;}
.about-strip-text h2{font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:700;margin-bottom:1.2rem;line-height:1.2;}
.about-strip-text h2 em{color:#e8b84b;font-style:italic;}
.about-strip-text p{color:rgba(255,255,255,0.75);font-size:1rem;line-height:1.8;margin-bottom:1.5rem;}
.about-strip-text a{display:inline-flex;align-items:center;gap:0.5rem;background:#e8b84b;color:#1c1c1c;padding:0.9rem 2rem;border-radius:3rem;text-decoration:none;font-weight:600;font-size:0.9rem;transition:all 0.2s;}
.about-strip-text a:hover{background:#fff;}
.about-stats{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;}
.about-stat-card{background:rgba(255,255,255,0.07);border-radius:16px;padding:1.5rem;border:1px solid rgba(255,255,255,0.1);text-align:center;transition:background 0.2s;}
.about-stat-card:hover{background:rgba(255,255,255,0.12);}
.about-stat-num{font-family:'Bebas Neue',sans-serif;font-size:3rem;color:#e8b84b;line-height:1;}
.about-stat-label{font-size:0.78rem;text-transform:uppercase;letter-spacing:0.12em;color:rgba(255,255,255,0.55);margin-top:0.4rem;}

/* ── NEWSLETTER ── */
.newsletter{padding:6rem 4rem;background:linear-gradient(135deg,#d4501a 0%,#c03a10 100%);color:#fff;text-align:center;position:relative;overflow:hidden;}
.newsletter::before{content:'✦';position:absolute;font-size:25rem;color:rgba(255,255,255,0.04);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;font-family:'Playfair Display',serif;}
.newsletter-eyebrow{font-size:0.72rem;text-transform:uppercase;letter-spacing:0.2em;color:rgba(255,255,255,0.6);margin-bottom:1rem;position:relative;z-index:1;}
.newsletter h2{font-family:'Playfair Display',serif;font-size:clamp(2rem,4vw,3rem);font-weight:900;margin-bottom:1rem;position:relative;z-index:1;}
.newsletter p{font-size:1rem;color:rgba(255,255,255,0.8);max-width:480px;margin:0 auto 2rem;position:relative;z-index:1;line-height:1.7;}
.nl-form{display:flex;max-width:460px;margin:0 auto;position:relative;z-index:1;box-shadow:0 8px 32px rgba(0,0,0,0.2);border-radius:3rem;}
.nl-form input{flex:1;padding:1.1rem 1.8rem;border:none;border-radius:3rem 0 0 3rem;font-family:'DM Sans',sans-serif;font-size:0.9rem;outline:none;background:#fff;}
.nl-form button{background:#1a3a2a;color:#fff;border:none;padding:1.1rem 2rem;border-radius:0 3rem 3rem 0;font-family:'DM Sans',sans-serif;font-size:0.9rem;font-weight:600;cursor:pointer;white-space:nowrap;transition:background 0.2s;}
.nl-form button:hover{background:#0f2318;}
.nl-note{font-size:0.75rem;color:rgba(255,255,255,0.45);margin-top:1.2rem;position:relative;z-index:1;}

/* ── FOOTER ── */
footer{background:#111;color:rgba(255,255,255,0.6);padding:4rem 4rem 2rem;}
.footer-inner{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem;margin-bottom:3rem;}
.footer-brand h3{font-family:'Playfair Display',serif;font-size:1.4rem;color:#fff;margin-bottom:0.75rem;font-style:italic;}
.footer-brand p{font-size:0.85rem;line-height:1.75;max-width:260px;margin-bottom:1.5rem;}
.social-row{display:flex;gap:0.75rem;}
.social-btn{width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:0.9rem;transition:background 0.2s;}
.social-btn:hover{background:#d4501a;}
.footer-col h4{color:#fff;font-size:0.78rem;text-transform:uppercase;letter-spacing:0.15em;margin-bottom:1.2rem;font-weight:600;}
.footer-col ul{list-style:none;}
.footer-col ul li{margin-bottom:0.6rem;}
.footer-col ul li a{font-size:0.85rem;color:rgba(255,255,255,0.5);text-decoration:none;transition:color 0.2s;}
.footer-col ul li a:hover{color:#e8b84b;}
.footer-bottom{border-top:1px solid rgba(255,255,255,0.08);padding-top:2rem;display:flex;justify-content:space-between;font-size:0.78rem;flex-wrap:wrap;gap:1rem;}
.footer-bottom a{color:rgba(255,255,255,0.35);text-decoration:none;margin-left:1.5rem;transition:color 0.2s;}
.footer-bottom a:hover{color:#e8b84b;}

/* ── ANIMATIONS ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(30px);}to{opacity:1;transform:translateY(0);}}
.fade-up{opacity:0;animation:fadeUp 0.8s ease forwards;}
.fade-up-1{animation-delay:0.1s;}
.fade-up-2{animation-delay:0.25s;}
.fade-up-3{animation-delay:0.4s;}
.fade-up-4{animation-delay:0.55s;}

/* ── RESPONSIVE ── */
@media(max-width:1100px){.blog-grid{grid-template-columns:repeat(2,1fr);}.blog-card.featured{grid-column:span 2;}.footer-inner{grid-template-columns:1fr 1fr;}}
@media(max-width:768px){
  nav{padding:1rem 1.5rem;}.nav-links{display:none;}.hamburger{display:flex;}.mobile-nav{display:flex;}
  .hero-content{padding:3rem 1.5rem;}.hero-stats{display:none;}.hero-dots{left:1.5rem;}
  .marquee-strip{display:none;}
  .filters-section,.blog-section{padding-left:1.5rem;padding-right:1.5rem;}
  .blog-grid{grid-template-columns:1fr;}.blog-card.featured{grid-column:span 1;grid-template-columns:1fr;}.blog-card.featured .card-img{height:220px;}
  .about-strip{grid-template-columns:1fr;padding:3rem 1.5rem;gap:2rem;}
  .newsletter{padding:4rem 1.5rem;}.nl-form{flex-direction:column;border-radius:16px;box-shadow:none;}.nl-form input{border-radius:3rem;margin-bottom:0.75rem;}.nl-form button{border-radius:3rem;}
  footer{padding:3rem 1.5rem 1.5rem;}.footer-inner{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<!-- NAV -->
<nav id="mainNav">
  <a class="nav-logo" href="/"><span>The</span> Unchained Girl</a>
  <ul class="nav-links">
    <li><a href="#blog">Stories</a></li>
    <li><a href="/about/">About</a></li>
    <li><a href="/contact/">Contact</a></li>
    <li><a href="#newsletter" class="nav-cta">Subscribe</a></li>
  </ul>
  <button class="hamburger" onclick="toggleMenu()"><span></span><span></span><span></span></button>
</nav>

<div class="mobile-nav" id="mobileNav">
  <a href="#blog" onclick="toggleMenu()">Stories</a>
  <a href="/about/" onclick="toggleMenu()">About</a>
  <a href="/contact/" onclick="toggleMenu()">Contact</a>
  <a href="#newsletter" onclick="toggleMenu()">Subscribe</a>
</div>

<!-- HERO SLIDESHOW -->
<section class="hero" id="hero">
  <div class="hero-bg" id="heroBg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <p class="hero-eyebrow fade-up fade-up-1">Unchained. Curious. Always Hungry.</p>
    <h1 class="hero-title fade-up fade-up-2">
      Free to Roam,
      <em>Free to Taste.</em>
    </h1>
    <p class="hero-sub fade-up fade-up-3">A Bangladeshi girl exploring the world — one trail, one meal, and one honest story at a time. From the delta to the mountains and everywhere in between.</p>
    <div class="hero-btns fade-up fade-up-4">
      <a href="#blog" class="btn-primary">Read Stories →</a>
      <a href="/about/" class="btn-outline">About Me</a>
    </div>
  </div>
  <div class="hero-dots" id="heroDots"></div>
  <div class="hero-stats">
    <div class="hero-stat"><div class="hero-stat-num">{{ collections.posts | length }}+</div><div class="hero-stat-label">Stories</div></div>
    <div class="hero-stat"><div class="hero-stat-num">10+</div><div class="hero-stat-label">Destinations</div></div>
    <div class="hero-stat"><div class="hero-stat-num">BD</div><div class="hero-stat-label">Based In</div></div>
  </div>
</section>

<!-- MARQUEE -->
<div class="marquee-strip">
  <div class="marquee-inner">
    <span>Food & Eating</span><span class="dot">✦</span>
    <span>Trekking & Adventure</span><span class="dot">✦</span>
    <span>Nature & Landscapes</span><span class="dot">✦</span>
    <span>Budget Travel</span><span class="dot">✦</span>
    <span>Bangladesh & Beyond</span><span class="dot">✦</span>
    <span>Honest Stories</span><span class="dot">✦</span>
    <span>Food & Eating</span><span class="dot">✦</span>
    <span>Trekking & Adventure</span><span class="dot">✦</span>
    <span>Nature & Landscapes</span><span class="dot">✦</span>
    <span>Budget Travel</span><span class="dot">✦</span>
    <span>Bangladesh & Beyond</span><span class="dot">✦</span>
    <span>Honest Stories</span><span class="dot">✦</span>
  </div>
</div>

<!-- FILTERS -->
<div class="filters-section" id="blog">
  <div class="filter-row">
    <span class="filter-label">Where:</span>
    <button class="filter-chip active" onclick="filterPosts(this,'region','all')">🌍 All</button>
    <button class="filter-chip" onclick="filterPosts(this,'region','home-country')">🇧🇩 Home</button>
    <button class="filter-chip" onclick="filterPosts(this,'region','abroad')">✈️ Abroad</button>
    <div class="filter-divider"></div>
    <span class="filter-label">Vibe:</span>
    <button class="filter-chip" onclick="filterPosts(this,'vibe','food')">🍜 Food</button>
    <button class="filter-chip" onclick="filterPosts(this,'vibe','trek')">🥾 Trek</button>
    <button class="filter-chip" onclick="filterPosts(this,'vibe','relax')">🌊 Relax</button>
    <button class="filter-chip" onclick="filterPosts(this,'vibe','community')">🤝 Community</button>
    <button class="filter-chip" onclick="filterPosts(this,'vibe','nature')">🌿 Nature</button>
  </div>
</div>

<!-- BLOG GRID -->
<section class="blog-section">
  <div class="blog-header">
    <div>
      <p class="section-eyebrow">Latest from the road</p>
      <h2 class="section-title">Recent Stories</h2>
    </div>
    <a href="#blog" class="view-all-link">View all →</a>
  </div>
  <div class="blog-grid" id="blogGrid">
    {%- set postcount = 0 -%}
    {%- for post in collections.posts | reverse -%}
      {%- set postcount = postcount + 1 -%}
      <a href="{{ post.url }}" class="blog-card{% if postcount == 1 %} featured{% endif %}" data-region="{{ post.data.region | lower | replace(' ','-') }}" data-vibe="{{ post.data.category | lower }}">
        <div class="card-img">
          {%- if post.data.cover_image -%}<img src="{{ post.data.cover_image }}" alt="{{ post.data.title }}" loading="lazy">{%- else -%}<div class="no-img">✈️</div>{%- endif -%}
          {%- if post.data.category -%}<span class="card-category">{{ post.data.category }}</span>{%- endif -%}
          {%- if post.data.location -%}<span class="card-location">📍 {{ post.data.location }}</span>{%- endif -%}
        </div>
        <div class="card-body">
          <p class="card-meta">{{ post.data.date | dateDisplay }}{%- if post.data.read_time -%} · {{ post.data.read_time }} min read{%- endif -%}</p>
          <h3 class="card-title">{{ post.data.title }}</h3>
          {%- if post.data.excerpt -%}<p class="card-excerpt">{{ post.data.excerpt }}</p>{%- endif -%}
          <div class="card-footer-row">
            <div class="card-tags">
              {%- if post.data.category -%}<span class="card-tag">{{ post.data.category }}</span>{%- endif -%}
              {%- if post.data.region -%}<span class="card-tag">{{ post.data.region }}</span>{%- endif -%}
            </div>
            {%- if post.data.read_time -%}<span class="card-read">⏱ {{ post.data.read_time }} min</span>{%- endif -%}
          </div>
        </div>
      </a>
    {%- else -%}
      <div class="no-posts"><p style="font-size:2rem;margin-bottom:1rem">✍️</p><p>No posts yet! Go to <a href="/admin/" style="color:#d4501a">/admin</a> to write your first story.</p></div>
    {%- endfor -%}
  </div>
</section>

